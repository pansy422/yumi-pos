{
  "name": "yumi-pos",
  "version": "0.1.0",
  "description": "Yumi POS - Software de punto de venta para minimarket",
  "main": "dist-electron/electron/main.js",
  "author": "Vicente - TokyoTech",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "build:vite": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:vite && npm run build:electron",
    "preview": "vite preview",
    "start": "concurrently -k -s first -n VITE,ELECTRON \"npm:dev\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dist": "npm run build && electron-builder --win --x64",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -w @thiagoelg/node-printer",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.5",
    "@thiagoelg/node-printer": "^0.6.2",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "node-thermal-printer": "^4.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
